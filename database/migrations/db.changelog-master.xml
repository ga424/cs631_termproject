<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- Initialize database schema -->
    <include file="01-init-schema.xml" relativeToChangelogFile="true"/>

    <!-- Add initial tables -->
    <include file="02-create-tables.xml" relativeToChangelogFile="true"/>

    <!-- Add business rule constraints -->
    <include file="03-add-business-constraints.xml" relativeToChangelogFile="true"/>

    <!-- Link customer records to login accounts -->
    <include file="04-create-customer-accounts.xml" relativeToChangelogFile="true"/>

    <!-- Add rental lifecycle audit events -->
    <include file="05-add-rental-lifecycle-events.xml" relativeToChangelogFile="true"/>

    <!-- Track requested return branch separately from pickup branch -->
    <include file="06-add-reservation-return-location.xml" relativeToChangelogFile="true"/>

</databaseChangeLog>
